{
  "manifest_version": 3,
  "name": "Cruelty-Free Checker",
  "version": "0.1.0",
  "description": "Check whether a brand is cruelty-free while browsing.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Cruelty-Free Checker"
  },
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}